# Atelier — Şahsî Ortam Değişkenleri (örnek)
# Bu dosyayı .env olarak kopyalayın ve değerleri kendi anahtarlarınızla doldurun.
# Ya da uygulamadaki Ayarlar > Yapay Zekâ ekranından girebilirsiniz.

# Anthropic Claude API anahtarı (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenAI API anahtarı (https://platform.openai.com)
OPENAI_API_KEY=

# WebDAV / Bulut yapılandırması (opsiyonel)
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
